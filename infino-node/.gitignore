# Rust build output
target/

# Node
node_modules/

# Compiled native addons — never committed, anywhere in the package
# (build output, release-staging copies, dry-run leftovers).
*.node

# napi-rs generated (regenerated by `napi build`)
infino/native.js
infino/native.d.ts

# tsc generated (regenerated by `tsc`)
infino/index.js
infino/index.d.ts

# misc
*.tgz

# Release staging — all generated, none committed. npm/ holds the
# per-platform package dirs, regenerated from package.json by
# `napi create-npm-dir` at release time (and by verify-pack); artifacts/
# is where CI drops the downloaded addons.
npm/
artifacts/
